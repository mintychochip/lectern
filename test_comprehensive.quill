// Comprehensive test for the bytecode compiler

// Basic arithmetic
let a = 10 + 5;
let b = 20 - 8;
let c = 3 * 4;
let d = 15 / 3;
let e = 17 % 5;

// Variables
let x = 10;
let y = 20;
let sum = x + y;

// Simple function
fn dub(n) {
    return n + n;
}

let doubled = dub(21);

// Nested function call
fn add(p, q) {
    return p + q;
}

fn mul(m, n) {
    return m * n;
}

let combined = add(mul(3, 4), 5);

// Control flow
let i = 0;
while i < 5 {
    i = i + 1;
}
print(i)

// Conditional
let max = 0;
if x > y {
    max = x;
} else {
    max = y;
}
