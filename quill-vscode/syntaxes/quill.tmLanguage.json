{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Quill",
  "scopeName": "source.quill",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.quill",
      "match": "//.*$"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.quill",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.quill",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.quill",
              "begin": "\\$\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.quill" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.quill" }
              },
              "patterns": [
                { "include": "#strings" },
                { "include": "#keywords" },
                { "include": "#operators" },
                { "include": "#numbers" },
                { "include": "#punctuation" },
                { "include": "#identifiers" }
              ]
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.quill",
          "match": "\\b(if|else|while|for|in|return|break|next)\\b"
        },
        {
          "name": "keyword.declaration.quill",
          "match": "\\b(let|const|fn|enum|class|extends|import|from)\\b"
        },
        {
          "name": "storage.type.quill",
          "match": "\\b(bool|int|float|double|string)\\b"
        },
        {
          "name": "constant.language.quill",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "keyword.operator.logical.quill",
          "match": "\\b(and|or|not|is)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.quill",
          "match": "(\\+\\+|--|\\+\\=|-\\=|\\*\\=|/\\=|%\\=|\\*\\*|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.comparison.quill",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.quill",
          "match": "(->|=)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.quill",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.quill",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.curly.quill",
          "match": "[{}]"
        },
        {
          "name": "punctuation.bracket.round.quill",
          "match": "[()]"
        },
        {
          "name": "punctuation.bracket.square.quill",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.separator.quill",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.accessor.quill",
          "match": "\\.\\.|\\."
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.quill",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
